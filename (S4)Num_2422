import sys
input = sys.stdin.readline

N, M = map(int, input().split())
dic = dict()
num = 0
for i in range(N):
    dic[i+1] = []
for i in range(M):
    a, b = map(int, input().split())
    dic[a].append(b)
    dic[b].append(a)
for i in range(1, N-1):
    for j in range(i+1, N):
        for k in range(j+1, N+1):
            if j not in dic[i] and k not in dic[i] and k not in dic[j]:
                num += 1
print(num)
