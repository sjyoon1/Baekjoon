import sys
input = sys.stdin.readline

N, K, A, B = map(int, input().split())
p = [K] * N
c = 0
d = 1
while True:
    for i in range(A):
        p[c] += B
        c += 1
        if c == N:
            c = 0
    for i in range(N):
        p[i] -= 1
    if p.count(0) > 0:
        print(d)
        break
    d += 1
