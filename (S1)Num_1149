import sys
input = sys.stdin.readline

N = int(input())
a = []
for i in range(N):
    b = list(map(int, input().split()))
    a.append(b)
for i in range(1, N):
    a[i][0] += min(a[i-1][1], a[i-1][2])
    a[i][1] += min(a[i-1][0], a[i-1][2])
    a[i][2] += min(a[i-1][1], a[i-1][0])

print(min(a[N-1]))
