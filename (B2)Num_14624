import sys
input = sys.stdin.readline

N = int(input())
if N % 2 == 0:
    print("I LOVE CBNU")
else:
    print("*"*N)
    for i in range(N//2 + 1):
        print(" "*(N//2 - i), end="")
        print("*", end="")
        if i != 0:
            print(" "*(2*i - 1), end="")
            print("*")
        else:
            print()
