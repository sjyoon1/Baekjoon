import sys
input = sys.stdin.readline

T = int(input())
for i in range(T):
    n = int(input())
    a = list(map(int, input().split()))
    b = list(map(int, input().split()))
    for j in range(1, n):
        a[j] = max(a[j-1], b[j-1] + a[j])
        b[j] = max(b[j-1], b[j] + a[j-1])
    print(max(a[n-1], b[n-1]))
