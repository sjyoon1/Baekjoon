import sys
input = sys.stdin.readline

N = int(input())
a = [[0] * N for i in range(N)]
b = []
for i in range(N):
    c = list(map(int, input().split()))
    b.append(c)

a[0][0] = 1
for i in range(N):
    for j in range(N):
        if a[i][j] != 0 and b[i][j] != 0:
            if i + b[i][j] < N:
                a[i+b[i][j]][j] += a[i][j]
            if j + b[i][j] < N:
                a[i][j+b[i][j]] += a[i][j]
print(a[N-1][N-1])
