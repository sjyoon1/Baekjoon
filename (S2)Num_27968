import sys
input = sys.stdin.readline

N, M = map(int, input().split())
A = list(map(int, input().split()))
a1 = [0, A[0]]
for i in range(1, M):
    A[i] += A[i-1]
    a1.append(A[i])
A = a1
for i in range(N):
    B = int(input())
    if B > A[M]:
        print("Go away!")
    else:
        s, e = 1, M
        while s <= e:
            mid = (s+e)//2
            if B <= A[mid]:
                c = mid
                e = mid - 1
            else:
                s = mid + 1
        print(c)
